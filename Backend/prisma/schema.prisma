
generator client {
  provider = "prisma-client"
  output   = "../src/db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id Int @id @default(autoincrement())
  username String @unique
  password String
  firstName String
  lastName String
  pictureURL String @default("https://res.cloudinary.com/dic5sskvu/image/upload/v1771032844/defaultAvatar_szkhjs.webp")
  bio String?
  profileBanner String @default("https://res.cloudinary.com/dic5sskvu/image/upload/v1772788070/default_cover_owaxyw.svg")
  sentMessages Message[] @relation("SentMessages")      // Matches sender
  receivedMessages Message[] @relation("ReceivedMessages") // Matches recipient
  groups Group[]
  friends User[] @relation("UserFriends")
  friendOf User[] @relation("UserFriends")
}

model Message{
  id Int @id @default(autoincrement())
  date DateTime @default(now())
  content String?
  imageUrl String?
  sender User @relation("SentMessages",fields:[senderId],references: [id])
  senderId Int
  recipent User? @relation("ReceivedMessages",fields:[recipentId],references: [id])
  recipentId Int?
  type Type
}

model Group{
  id Int @id @default(autoincrement())
  name String
  pictureUrl String
  users User[]
}


enum Type{
  GLOBAL
  DIRECTED
  GROUP
}
 
